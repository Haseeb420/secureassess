# ==============================================================================
# API (FastAPI) — PRODUCTION ENVIRONMENT TEMPLATE
# These values are injected as Fly.io secrets — never stored as files on server.
#
# To push all secrets to Fly.io:  make fly-secrets
# To set a single secret:         fly secrets set KEY=value --app secureassess-api
# To view current secrets:        fly secrets list --app secureassess-api
#
# For local dev values see: .env.example
# ==============================================================================

# ── Application ───────────────────────────────────────────────────────────────
# Set automatically by fly.toml — do not push via fly secrets
# ENVIRONMENT=production

# ── Supabase (cloud) ──────────────────────────────────────────────────────────
# Supabase dashboard → your project → Project Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-public-key>
SUPABASE_SERVICE_KEY=<service-role-key>
# Project Settings → API → JWT Settings
SUPABASE_JWT_SECRET=<jwt-secret>

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase dashboard → Project Settings → Database → Connection string → URI (Transaction pooler)
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# ── Better Auth ───────────────────────────────────────────────────────────────
BETTER_AUTH_URL=https://admin-delta-ecru.vercel.app
BETTER_AUTH_SECRET=<random-string-at-least-32-chars>   # Must match Vercel env var
ADMIN_URL=https://admin-delta-ecru.vercel.app

# ── Secrets ───────────────────────────────────────────────────────────────────
ENCRYPTION_SECRET=<64-char-hex-string>   # Generate: openssl rand -hex 32
JWT_SECRET=<same-as-SUPABASE_JWT_SECRET>

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# Create App Password at: https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=hiring@example.com
GMAIL_APP_PASSWORD=<app-password>

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
