ENVIRONMENT=development

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── API ───────────────────────────────────────────────────────────────────────
# dev
API_BASE_URL=http://localhost:8000
# PROD: API_BASE_URL=https://secureassess-api.fly.dev

# ── Better Auth ───────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=your-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
# dev — local PostgreSQL (run: make db-setup  or  make db-setup-docker)
DATABASE_URL=postgresql://secureassess:secureassess@localhost:5432/secureassess
# PROD: DATABASE_URL=postgresql://postgres.[project]:[password]@[host]:5432/postgres
