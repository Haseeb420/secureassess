# ==============================================================================
# DESKTOP APP (Tauri/Vite) — LOCAL DEVELOPMENT ENVIRONMENT
# Copy this file to .env — values below work out of the box after:
#   make supabase-start && make supabase-migrate
#
# VITE_* variables are embedded into the JS bundle at build time (not runtime).
# For production values see: .env.production.example
# Production values are injected by GitHub Actions from repository secrets.
# See: .github/workflows/release.yml → "Build Tauri app" step.
# ==============================================================================

ENVIRONMENT=development

# ── API ───────────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000

# ── Admin Dashboard ───────────────────────────────────────────────────────────
VITE_ADMIN_URL=http://localhost:3000
VITE_BETTER_AUTH_URL=http://localhost:3000

# ── Supabase (local) ──────────────────────────────────────────────────────────
# Well-known default keys for every local Supabase instance — not real secrets.
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRFA0NiK7kyqd6Cr0xGjrqfPCv_fXCODmNFxjgAqoKA

# ── Code Execution ────────────────────────────────────────────────────────────
# Judge0 Docker image (linux/amd64) cannot run on Apple Silicon under Rosetta 2
# nested emulation — use LocalExecutor for dev, Judge0 for production.
VITE_JUDGE0_URL=
VITE_EXECUTION_BACKEND=local
