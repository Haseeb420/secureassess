# ==============================================================================
# DESKTOP APP (Tauri/Vite) — PRODUCTION ENVIRONMENT TEMPLATE
# These values are injected by GitHub Actions at build time from repository secrets.
# See: .github/workflows/release.yml → "Build Tauri app" step.
#
# To update a GitHub secret:  gh secret set <NAME> --body "<value>"
# To sync all GitHub secrets: make secrets-sync
#
# For local dev values see: .env.example
# ==============================================================================

ENVIRONMENT=production

# ── API ───────────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=https://secureassess-api.fly.dev

# ── Admin Dashboard ───────────────────────────────────────────────────────────
VITE_ADMIN_URL=https://admin-delta-ecru.vercel.app
VITE_BETTER_AUTH_URL=https://admin-delta-ecru.vercel.app

# ── Supabase (cloud) ──────────────────────────────────────────────────────────
# Supabase dashboard → your project → Project Settings → API
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-public-key>

# ── Code Execution ────────────────────────────────────────────────────────────
VITE_JUDGE0_URL=https://unkind-freeware-unmoved.ngrok-free.dev
VITE_EXECUTION_BACKEND=judge0
