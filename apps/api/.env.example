# ==============================================================================
# API (FastAPI) — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in the values.
# ==============================================================================
#
# PRODUCTION values are injected as Fly.io secrets — never stored in this file.
# LOCAL DEVELOPMENT values are provided below as safe defaults where possible.
#
# To push secrets to Fly.io:    make fly-secrets
# To view Fly.io secrets:       fly secrets list --app secureassess-api
# To set a single secret:       fly secrets set KEY=value --app secureassess-api
# To push GitHub secrets:       make secrets-sync
# ==============================================================================

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
# PROD: ENVIRONMENT=production  (set automatically by fly.toml)

# ── Supabase Auth ─────────────────────────────────────────────────────────────
# Find these in: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-public-key>
SUPABASE_SERVICE_KEY=<service-role-key>       # Never expose in frontend
SUPABASE_JWT_SECRET=<jwt-secret>              # Project Settings → API → JWT Settings

# ── Database ──────────────────────────────────────────────────────────────────
# Option A — local native PostgreSQL (after: make db-setup)
DATABASE_URL=postgresql://secureassess:secureassess@localhost:5432/secureassess
# Option B — local Docker PostgreSQL (after: make db-setup-docker)
# DATABASE_URL=postgresql://secureassess:secureassess@localhost:5432/secureassess
# Option C — Supabase cloud (production / pooler URL from Supabase dashboard)
# DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres

# ── Better Auth ───────────────────────────────────────────────────────────────
# BETTER_AUTH_URL must match the URL where the admin dashboard is served.
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=<random-string-at-least-32-chars>   # Must match apps/admin/.env.local
ADMIN_URL=http://localhost:3000
# PROD:
# BETTER_AUTH_URL=https://admin-delta-ecru.vercel.app
# ADMIN_URL=https://admin-delta-ecru.vercel.app

# ── Secrets ───────────────────────────────────────────────────────────────────
ENCRYPTION_SECRET=<64-char-hex-string>   # Used for submission HMAC signing
JWT_SECRET=<same-as-SUPABASE_JWT_SECRET> # Must match Supabase JWT secret

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# Create an App Password at: https://myaccount.google.com/apppasswords
# Leave empty to disable email sending in local dev.
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
# PROD: fly secrets set GMAIL_ADDRESS=hiring@example.com GMAIL_APP_PASSWORD=xxxx --app secureassess-api

# ── Code Execution ────────────────────────────────────────────────────────────
# NOTE: execution is routed through the Rust desktop app (EvaluationBackend trait),
# not through the Python API. These vars are reserved for a future server-side
# execution path and are currently unused by the API.
EXECUTION_BACKEND=local
JUDGE0_URL=http://localhost:2358
JUDGE0_API_KEY=
JUDGE0_AUTH_TOKEN=
# PROD (desktop-level): VITE_JUDGE0_URL=https://unkind-freeware-unmoved.ngrok-free.dev

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO   # DEBUG | INFO | WARNING | ERROR

# ── ngrok (Judge0 tunnel — run on ASUS machine, not the dev machine) ──────────
# Only needed if you operate the Judge0 server yourself.
NGROK_STATIC_DOMAIN=unkind-freeware-unmoved.ngrok-free.dev
