# ==============================================================================
# ADMIN DASHBOARD (Next.js) — LOCAL DEVELOPMENT ENVIRONMENT
# Copy this file to .env.local — values below work out of the box after:
#   make supabase-start && make supabase-migrate
#
# NEXT_PUBLIC_* variables are exposed to the browser bundle.
# Non-prefixed variables stay server-side only.
#
# For production values see: .env.production.local.example
# Production values are managed in Vercel (encrypted): make vercel-env
# ==============================================================================

ENVIRONMENT=development

# ── Supabase (local) ──────────────────────────────────────────────────────────
# Well-known default keys for every local Supabase instance — not real secrets.
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRFA0NiK7kyqd6Cr0xGjrqfPCv_fXCODmNFxjgAqoKA

# ── API ───────────────────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:8000

# ── Better Auth ───────────────────────────────────────────────────────────────
# Must match BETTER_AUTH_SECRET in apps/api/.env
BETTER_AUTH_SECRET=local-dev-better-auth-secret-change-in-production
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
# Local Supabase bundles its own PostgreSQL on port 54322 — no separate DB needed.
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
