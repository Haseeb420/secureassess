# ==============================================================================
# ADMIN DASHBOARD (Next.js) — PRODUCTION ENVIRONMENT TEMPLATE
# Production values are managed in Vercel (encrypted environment variables).
#
# To push all vars to Vercel:  make vercel-env
# To add a single var:         vercel env add <KEY> production
# To list current vars:        vercel env ls
#
# For local dev values see: .env.local.example
# ==============================================================================

ENVIRONMENT=production

# ── Supabase (cloud) ──────────────────────────────────────────────────────────
# Supabase dashboard → your project → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# ── API ───────────────────────────────────────────────────────────────────────
API_BASE_URL=https://secureassess-api.fly.dev

# ── Better Auth ───────────────────────────────────────────────────────────────
# Must match BETTER_AUTH_SECRET in Fly.io secrets
BETTER_AUTH_SECRET=<random-string-at-least-32-chars>
BETTER_AUTH_URL=https://admin-delta-ecru.vercel.app
NEXT_PUBLIC_BETTER_AUTH_URL=https://admin-delta-ecru.vercel.app

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase dashboard → Project Settings → Database → Connection string → URI (Transaction pooler)
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
