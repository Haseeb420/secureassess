# ==============================================================================
# DESKTOP APP (Tauri/Vite) — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in the values.
# ==============================================================================
#
# VITE_* variables are embedded into the JS bundle at build time (not runtime).
# Production values are injected by GitHub Actions from repository secrets.
# See: .github/workflows/release.yml → "Build Tauri app" step.
#
# To update a GitHub secret: gh secret set <NAME> --body "<value>"
# To sync all GitHub secrets: make secrets-sync
# ==============================================================================

ENVIRONMENT=development

# ── API ───────────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
# PROD: VITE_API_BASE_URL=https://secureassess-api.fly.dev

# ── Admin Dashboard ───────────────────────────────────────────────────────────
VITE_ADMIN_URL=http://localhost:3000
VITE_BETTER_AUTH_URL=http://localhost:3000
# PROD:
# VITE_ADMIN_URL=https://admin-delta-ecru.vercel.app
# VITE_BETTER_AUTH_URL=https://admin-delta-ecru.vercel.app

# ── Supabase ──────────────────────────────────────────────────────────────────
# Shared project — same URL/anon key for dev and prod.
# Find these in: Supabase dashboard → Project Settings → API
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-public-key>

# ── Code Execution ────────────────────────────────────────────────────────────
# Judge0 Docker image (linux/amd64) cannot run on Apple Silicon under Rosetta 2
# nested emulation — isolate's mmap calls fault. Use local executor for dev.
# CI builds on Linux runners inject VITE_EXECUTION_BACKEND=judge0 via GitHub Secrets.
VITE_JUDGE0_URL=
VITE_EXECUTION_BACKEND=local
# PROD:
# VITE_JUDGE0_URL=https://unkind-freeware-unmoved.ngrok-free.dev
# VITE_EXECUTION_BACKEND=judge0
