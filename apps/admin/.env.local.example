# ==============================================================================
# ADMIN DASHBOARD (Next.js) — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in the values.
# ==============================================================================
#
# NEXT_PUBLIC_* variables are exposed to the browser bundle.
# Non-prefixed variables stay server-side only.
# Production values are managed in Vercel (encrypted) and pushed via: make vercel-env
#
# GitHub Secret        → Vercel variable name
# ─────────────────────────────────────────────────────────────────────────────
# SUPABASE_URL         → NEXT_PUBLIC_SUPABASE_URL
# VITE_SUPABASE_ANON_KEY → NEXT_PUBLIC_SUPABASE_ANON_KEY  (same value, diff name)
# BETTER_AUTH_SECRET   → BETTER_AUTH_SECRET               (exact match)
#
# To push all vars to Vercel: make vercel-env
# To add a single var:        make vercel-env-set KEY=X VALUE=Y
# ==============================================================================

ENVIRONMENT=development

# ── Supabase ──────────────────────────────────────────────────────────────────
# Find these in: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# ── API ───────────────────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:8000
# PROD: API_BASE_URL=https://secureassess-api.fly.dev

# ── Better Auth ───────────────────────────────────────────────────────────────
# BETTER_AUTH_SECRET must match the value in apps/api/.env.
# BETTER_AUTH_URL is the URL where this admin dashboard is served.
BETTER_AUTH_SECRET=<random-string-at-least-32-chars>
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
# PROD:
# BETTER_AUTH_URL=https://admin-delta-ecru.vercel.app
# NEXT_PUBLIC_BETTER_AUTH_URL=https://admin-delta-ecru.vercel.app

# ── Database ──────────────────────────────────────────────────────────────────
# dev — local PostgreSQL (run: make db-setup  or  make db-setup-docker)
DATABASE_URL=postgresql://secureassess:secureassess@localhost:5432/secureassess
# PROD: DATABASE_URL=postgresql://postgres.<ref>:<password>@<pooler-host>:5432/postgres
